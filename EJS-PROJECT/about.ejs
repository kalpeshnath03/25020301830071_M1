<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
</head>

<body>
    <h1>
        <%= title %>
    </h1>
    <p>
        <%= message %>
    </p>
    <ul>
        <% items.forEach(item=> { %>
            <li>
                <%= item %>
            </li>

            <% }); %>
    </ul>
    <table border="1">
        <tr>
            <th>Name</th>
            <th>Age</th>
        </tr>
        <% users.forEach(user => { %>
            <tr>
                <td>
                    <%= user.name %>
                </td>
                <td>
                    <%= user.age %>
                </td>
            </tr>

            <% }); %>

    </table>
</body>

</html>